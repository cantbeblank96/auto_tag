{
    "work_dir": "{PROJECT_PATH}/work_dir",
    "batch_size": 32,
    "tau_dup": 0.05,
    "tau_cls": 0.25,
    "embedding_subdir": "embedding_index",
    "record_stage1_duplicates": true,
    "duplicate_links_filename": "duplicate_links.sqlite",
    "device": "cuda",
    "vlm_models": [
        {
            "id": "00000000-0000-4000-8000-000000000001",
            "name": "gemini/gemini-2.5-flash",
            "base_url": null,
            "api_key": "your_api_key_here",
            "priority": 1,
            "enabled": true
        }
    ],
    "questions": {
        "scene": {
            "description": "description of the overall scene",
            "type": "string"
        },
        "time_of_day": {
            "description": "Determine the shooting time shown in the picture scene",
            "type": "category",
            "choices": ["day", "night", "unknown"]
        },
        "num_of_person": {
            "description": "Number of people in the picture",
            "type": "int",
            "min": 0
        },
        "brightness": {
            "description": "Brightness of the picture (0 to 10 points, the bigger, the brighter)",
            "type": "float",
            "min": 0,
            "max": 10,
            "step": 0.1
        }
    },
    "vlm_strategy": "round_robin",
    "vlm_concurrency": 10,
    "vlm_http_timeout": 60,
    "vlm_validation_max_corrections": 2,
    "circuit_breaker": {
        "time_window_seconds": 300,
        "failure_rate_threshold": 0.5,
        "cooldown_seconds": 600
    },
    "pipeline_debug": false
}
